# Space invocation mode
# Options:
#   mock    - cache-only, deterministic, fast (default — for training)
#   live    - always live HF API, slow, non-deterministic (for demos)
#   record  - live + cache responses (for populating fixtures)
#   hybrid  - try cache first, fall back to live on miss, auto-cache
#             (best for iterative dev + demo safety net)
SPACES_MODE=mock

# HuggingFace credentials (only needed for live/record mode)
HF_TOKEN=

# LLM API for inference agent + LLM judges in Auditor/Expert
OPENAI_API_KEY=
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Demo flags
DEMO_MODE=false
DEMO_LIVE_TOGGLE=false
