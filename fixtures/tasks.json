    "expected_output_schema": {
      "transcript_en": "string",
      "translation_fr": "string",
      "audio_url_fr": "string"
    },
    "max_actions": 15,
    "max_space_calls": 5,
    "expert_persona": "accuracy_first",
    "expert_rubric": {
      "transcript_en": {
        "weight": 0.3,
        "method": "min_length",
        "min_length": 30
      },
      "translation_fr": {
        "weight": 0.3,
        "method": "min_length",
        "min_length": 30
      },
      "audio_url_fr": {
        "weight": 0.4,
        "method": "non_empty"
      }
    },
    "gold_pipeline": [
      {
        "space_id": "hf-audio/whisper-large-v3",
        "inputs": {
          "inputs": "<input.audio_url>",
          "task": "transcribe"
        }
      },
      {
        "space_id": "UNESCO/nllb",
        "inputs": {
          "text": "<step1.transcript>",
          "src_lang": "English",
          "tgt_lang": "French"
        }
      },
      {
        "space_id": "innoai/Edge-TTS-Text-to-Speech",
        "inputs": {
          "text": "<step2.text>",
          "voice": "fr-FR-DeniseNeural - fr-FR (Female)",
          "rate": 0,
          "pitch": 0
        }
      }
    ]
  },
